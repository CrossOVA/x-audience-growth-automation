        "jsCode": "const target = $('Process One by One').item.json;\n\nreturn [\n  {\n    json: {\n      target_user_id: String(target.target_user_id || '').trim(),\n      username: target.username || '',\n      tier: target.tier || '',\n      Status: 'Followed',\n      Like_Sent: target.need_like ? 'Yes' : 'No',\n      Follow_Date: $now.toFormat('yyyy-MM-dd HH:mm:ss'),\n      Unfollow_Date: null\n    }\n  }\n];\n"
