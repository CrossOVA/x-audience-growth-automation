      "name": "Get Today Likes SQL",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const today = $now.toFormat('yyyy-MM-dd');\n\nconst tweets = $('Search Fresh Replies').item.json.data || [];\nconst users = $('Search Fresh Replies').item.json.includes?.users || [];\n\nfunction rowsFromNode(nodeName) {\n  const items = $(nodeName).all() || [];\n\n  if (!items.length) return [];\n\n  const first = items[0].json;\n\n  if (Array.isArray(first)) {\n    return first;\n  }\n\n  return items\n    .map(item => item.json)\n    .filter(row => row && Object.keys(row).length > 0 && !row.error);\n}\n\nconst knownRows = rowsFromNode('Get Already Followed Users SQL');\nconst todayLikeRows = rowsFromNode('Get Today Likes SQL');\n\nconst knownIds = new Set(\n  knownRows\n    .map(row => String(row.target_user_id || '').trim())\n    .filter(Boolean)\n);\n\nlet botLikesToday = 0;\n\ntry {\n  botLikesToday = todayLikeRows.filter(row => {\n    const likeSent = String(row.Like_Sent || '').trim().toLowerCase() === 'yes';\n    const followDate = String(row.Follow_Date || '').trim();\n\n    return likeSent && followDate.startsWith(today);\n  }).length;\n} catch (e) {\n  botLikesToday = 0;\n}\n\nconst SAFE_BOT_LIMIT = 180;\nlet currentTotalLikes = botLikesToday;\n\nconst validUsers = users.filter(u => {\n  const canFollow = (u.public_metrics?.following_count || 0) < 4995;\n  const isNew = !knownIds.has(String(u.id));\n  return canFollow && isNew;\n});\n\nlet tier1 = validUsers.filter(u => {\n  const fers = u.public_metrics?.followers_count || 0;\n  const fing = u.public_metrics?.following_count || 0;\n  return fers >= 5 && fers <= 3500 && fing >= (fers * 0.9);\n});\n\nlet tier2 = validUsers.filter(u => {\n  const fers = u.public_metrics?.followers_count || 0;\n  const fing = u.public_metrics?.following_count || 0;\n  const notInTier1 = !tier1.find(t1 => t1.id === u.id);\n  return notInTier1 && fing >= (fers * 0.3) && fers < 10000;\n});\n\nconst sortByHunger = (a, b) => {\n  const ratioA = (a.public_metrics?.following_count || 0) / ((a.public_metrics?.followers_count || 0) || 1);\n  const ratioB = (b.public_metrics?.following_count || 0) / ((b.public_metrics?.followers_count || 0) || 1);\n  return ratioB - ratioA;\n};\n\ntier1.sort(sortByHunger);\ntier2.sort(sortByHunger);\n\nconst finalTargets = [...tier1, ...tier2];\n\nreturn finalTargets.map((t) => {\n  const userTweet = tweets.find(tw => tw.author_id === t.id);\n  const ratio = (t.public_metrics?.following_count || 0) / ((t.public_metrics?.followers_count || 0) || 1);\n\n  let willLike = false;\n  const isGolden = ratio >= 0.3 && ratio <= 1.5;\n  const hasBudget = currentTotalLikes < SAFE_BOT_LIMIT;\n\n  if (userTweet && isGolden && hasBudget) {\n    willLike = true;\n    currentTotalLikes++;\n  }\n\n  return {\n    json: {\n      target_user_id: t.id,\n      username: t.username,\n      tweet_id: userTweet ? userTweet.id : null,\n      tier: tier1.find(t1 => t1.id === t.id) ? 'Tier 1' : 'Tier 2',\n      followers: t.public_metrics?.followers_count || 0,\n      following: t.public_metrics?.following_count || 0,\n      need_like: willLike\n    }\n  };\n});\n"
      },
