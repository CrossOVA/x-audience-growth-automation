    {
      "parameters": {
        "jsCode": "const pools = [\n  \"(to:NEWS_ACCOUNT_1 OR to:NEWS_ACCOUNT_2 OR to:INDUSTRY_ACCOUNT_1 OR to:INDUSTRY_ACCOUNT_2) is:reply -is:retweet\",\n  \"(to:INFLUENCER_ACCOUNT_1 OR to:INFLUENCER_ACCOUNT_2 OR to:ANALYST_ACCOUNT_1 OR to:ANALYST_ACCOUNT_2) is:reply -is:retweet\",\n  \"(to:FOUNDER_ACCOUNT_1 OR to:ETF_ANALYST_ACCOUNT OR to:PROJECT_ACCOUNT_1 OR to:MARKET_ACCOUNT_1) is:reply -is:retweet\"\n];\n\nconst randomIndex = Math.floor(Math.random() * pools.length);\n\nreturn [{\n  json: {\n    query: pools[randomIndex],\n    pool_index: randomIndex + 1\n  }\n}];"
      },
