    {
      "parameters": {
        "jsCode": "const users = $('Search Fresh Replies').item.json.includes?.users || [];\n\nconst ids = [...new Set(\n  users\n    .map(u => String(u.id || '').trim())\n    .filter(Boolean)\n)];\n\nconst idsFilter = ids.length ? `in.(${ids.join(',')})` : 'in.(0)';\n\nreturn [\n  {\n    json: {\n      ids_filter: idsFilter,\n      today_start: $now.startOf('day').toFormat(\"yyyy-MM-dd'T'HH:mm:ss\"),\n      tomorrow_start: $now.plus({ days: 1 }).startOf('day').toFormat(\"yyyy-MM-dd'T'HH:mm:ss\")\n    }\n  }\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
